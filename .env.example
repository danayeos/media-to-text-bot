# ─── COPY THIS FILE TO .env AND FILL IN YOUR VALUES ─────────────────────────
# Command: cp .env.example .env   (Mac/Linux)
#          copy .env.example .env (Windows)
# ─────────────────────────────────────────────────────────────────────────────

# Your Telegram Bot Token (get from @BotFather on Telegram)
BOT_TOKEN=your_token_here

# Whisper model size: tiny | base | small | medium | large
# Recommendation: "base" for most cases
WHISPER_MODEL=base

# Language for transcription (leave empty for auto-detect)
# Examples: en, ru, kk
WHISPER_LANGUAGE=

# Tesseract OCR languages (must be installed)
# Examples: eng | eng+rus | eng+rus+kaz
TESSERACT_LANG=eng+rus

# Max file size in MB (Telegram free tier limit is 20 MB)
MAX_FILE_SIZE_MB=20
